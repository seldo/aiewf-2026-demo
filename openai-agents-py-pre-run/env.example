# OpenAI API Key (for GPT model, used by Python backend)
OPENAI_API_KEY=sk-your-key-here

# NextAuth Configuration
# Insecure local demo: login is a no-op credentials provider (no OAuth).
# NEXTAUTH_SECRET is still used to sign the session JWT.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Backend communication (shared secret between Next.js and Python backend)
BACKEND_SECRET=generate-a-shared-secret-here
BACKEND_URL=http://localhost:8001

# ChromaDB (used by Python backend)
CHROMA_URL=http://localhost:8000

# Arize AX
# Get these from https://app.arize.com/organizations/-/settings/space-api-keys
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=wonder-toys-openai-agents-py
